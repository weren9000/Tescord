listening-port=3478
tls-listening-port=5349

fingerprint
use-auth-secret
static-auth-secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
realm=chat.example.com
server-name=chat.example.com

external-ip=YOUR_SERVER_PUBLIC_IP

lt-cred-mech
total-quota=100
bps-capacity=0
stale-nonce=600
no-loopback-peers
no-multicast-peers

cert=/etc/letsencrypt/live/chat.example.com/fullchain.pem
pkey=/etc/letsencrypt/live/chat.example.com/privkey.pem
